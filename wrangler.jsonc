{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "coastline-studio-0607",
  "compatibility_date": "2026-07-12",
  "main": "functions/api/mockup.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "vars": {
    "CONTACT_EMAIL": "forms@coastlinestudio.ca",
    "FROM_EMAIL": "Coastline Studio <forms@coastlinestudio.ca>"
  }
}
